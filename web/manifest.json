{
    "name": "OCR Scanner",
    "short_name": "OCR",
    "start_url": ".",
    "scope": "/",
    "display": "standalone",
    "background_color": "#0D1117",
    "theme_color": "#238636",
    "description": "Share images from any app and extract text using OCR. Supports English and Hindi.",
    "orientation": "portrait-primary",
    "prefer_related_applications": false,
    "share_target": {
        "action": "/share-target",
        "method": "POST",
        "enctype": "multipart/form-data",
        "params": {
            "files": [
                {
                    "name": "sharedimages",
                    "accept": ["image/*"]
                }
            ]
        }
    },
    "icons": [
        {
            "src": "icons/Icon-192.png",
            "sizes": "192x192",
            "type": "image/png"
        },
        {
            "src": "icons/Icon-512.png",
            "sizes": "512x512",
            "type": "image/png"
        },
        {
            "src": "icons/Icon-maskable-192.png",
            "sizes": "192x192",
            "type": "image/png",
            "purpose": "maskable"
        },
        {
            "src": "icons/Icon-maskable-512.png",
            "sizes": "512x512",
            "type": "image/png",
            "purpose": "maskable"
        }
    ]
}
